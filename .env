# ─────────────────────────────────────────────
# Gemma4 Project — Environment Configuration
# ─────────────────────────────────────────────
# Edit this file to change models, ports, or memory limits.
# After any change: docker compose down && docker compose up -d

# The Ollama model to pre-load when the stack starts.
# Gemma 4 options: gemma3:2b  |  gemma3:9b  |  gemma3:27b
# (We start light — swap to a bigger one when you're ready)
OLLAMA_MODEL=gemma3:2b

# Where Ollama is running on your Mac (do not change unless you moved the port)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Port Open WebUI will be available on in your browser
WEBUI_PORT=3000

# Open WebUI data directory (chat history, settings — lives on your Mac)
WEBUI_DATA=./data/open-webui
